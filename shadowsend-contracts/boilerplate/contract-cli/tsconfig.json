{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    // "rootDir": "src",
    "rootDir": "src",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "declaration": true,
    "lib": ["ESNext"],
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strict": true,
    "isolatedModules": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
